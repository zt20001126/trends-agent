# 应用配置示例。复制为 .env 后填写真实密钥，禁止提交真实 .env。
APP_NAME=trends-agent
APP_ENV=development
DEBUG=true

# DeepSeek 配置。真实 API Key 只允许放在本地 .env。
DEEPSEEK_API_KEY=replace_with_your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=60
DEEPSEEK_TEMPERATURE=0.2
DEEPSEEK_MAX_TOKENS=3000
DEEPSEEK_REVIEW_SAMPLE_LIMIT=50

# PostgreSQL Docker 配置。
POSTGRES_DB=trends_agent
POSTGRES_USER=trends_agent
POSTGRES_PASSWORD=trends_agent_dev_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://trends_agent:trends_agent_dev_password@localhost:5432/trends_agent

# 选品分析默认配置。
DEFAULT_COUNTRY=US
DEFAULT_LANGUAGE=zh-CN
AMAZON_DATA_MODE=sample
